{
  "manifest_version": 3,
  "name": "WAN Download URL Helper",
  "version": "1.2",
  "description": "Show the URL behind hovered download buttons (e.g. ComfyUI WAN).",
  "permissions": ["contextMenus", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "wan-download-url-128.png"
  },
  "action": {
    "default_icon": {
      "128": "wan-download-url-128.png"
    },
    "default_title": "WAN Download URL Helper"
  }
}
